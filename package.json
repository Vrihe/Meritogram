{
  "name": "prowadlabor-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "init-env": "shx cp -n Backend/.env.example Backend/.env",
    "dev": "npm run init-env && concurrently \"docker-compose up --build\" \"cd Frontend && npm start\"",
    "start": "npm run dev",
    "stop": "docker-compose down"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "shx": "^0.4.0"
  }
}